{
  "manifest_version": 3,
  "name": "Text Helper MVP",
  "version": "0.1.0",
  "description": "A minimal Chrome extension MVP for selected text collection.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}

